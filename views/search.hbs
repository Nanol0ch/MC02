<div class="bg-primary text-white py-4" style="padding-left: 50px; padding-right: 50px;">
    <h2> Find Your Flight </h2>
    <p class="mb-0"> Search across top airlines </p>
</div>

<div id="mainContent" class="my-4">
<div class="card mb-4">
    <div class="card-body">

        <h5> Search Flights </h5>

        <div class="mb-3" id="tripToggle">
            <button type="button" class="btn btn-outline-primary" id="oneWayBtn"> One Way </button>
            <button type="button" class="btn btn-primary" id="roundTripBtn"> Round Trip </button>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label> Origin Airport </label>
                <select class="form-select" id="origin">
                    <option value=""> -- Select Origin -- </option>
                    <option value="MNL"> Manila (MNL) </option>
                    <option value="CEB"> Cebu (CEB) </option>
                    <option value="DVO"> Davao (DVO) </option>
                    <option value="SIN"> Singapore (SIN) </option>
                    <option value="HKG"> Hong Kong (HKG) </option>
                    <option value="DXB"> Dubai (DXB) </option>
                    <option value="NRT"> Tokyo (NRT) </option>
                    <option value="SYD"> Sydney (SYD) </option>
                </select>
                <small class="text-danger d-none" id="originError"> Please select an origin. </small>
            </div>
            <div class="col-md-6">
                <label> Destination Airport </label>
                <select class="form-select" id="destination">
                    <option value=""> -- Select Destination -- </option>
                    <option value="MNL"> Manila (MNL) </option>
                    <option value="CEB"> Cebu (CEB) </option>
                    <option value="DVO"> Davao (DVO) </option>
                    <option value="SIN"> Singapore (SIN) </option>
                    <option value="HKG"> Hong Kong (HKG) </option>
                    <option value="DXB"> Dubai (DXB) </option>
                    <option value="NRT"> Tokyo (NRT) </option>
                    <option value="SYD"> Sydney (SYD) </option>
                </select>
                <small class="text-danger d-none" id="destinationError"> Please select a destination. </small>
                <small class="text-danger d-none" id="sameRouteError"> Origin and destination cannot be the same. </small>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label> Departure Date </label>
                <input type="date" class="form-control" id="departureDate">
                <small class="text-danger d-none" id="departureDateError"> Please select a departure date. </small>
            </div>
            <div class="col-md-6" id="returnDateSection">
                <label> Return Date </label>
                <input type="date" class="form-control" id="returnDate">
                <small class="text-danger d-none" id="returnDateError"> Return date must be after departure. </small>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <label> Passengers </label>
                <div class="card p-2" id="passengerBox">
                    <div class="d-flex justify-content-between mb-2">
                        <span> Adults </span>
                        <div>
                            <button type="button" class="btn btn-outline-secondary" id="adultMinus"> - </button>
                            <span id="adultCount"> 1 </span>
                            <button type="button" class="btn btn-outline-secondary" id="adultPlus"> + </button>
                        </div>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span> Children </span>
                        <div>
                            <button type="button" class="btn btn-outline-secondary" id="childMinus"> - </button>
                            <span id="childCount"> 0 </span>
                            <button type="button" class="btn btn-outline-secondary" id="childPlus"> + </button>
                        </div>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span> Infants </span>
                        <div>
                            <button type="button" class="btn btn-outline-secondary" id="infantMinus"> - </button>
                            <span id="infantCount"> 0 </span>
                            <button type="button" class="btn btn-outline-secondary" id="infantPlus"> + </button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <label> Cabin Class </label>
                <select class="form-select" id="cabinClass">
                    <option value="Economy"> Economy </option>
                    <option value="Premium Economy"> Premium Economy </option>
                    <option value="Business"> Business </option>
                    <option value="First Class"> First Class </option>
                </select>
            </div>
        </div>

        <div class="accordion mb-3" id="advancedAccordion">
            <div class="accordion-item">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#advancedSearch"> Advanced Search </button>
                </h2>
                <div id="advancedSearch" class="accordion-collapse collapse">
                    <div class="accordion-body">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label> Preferred Airline </label>
                                <select class="form-select" id="preferredAirline">
                                    <option value=""> Any Airline </option>
                                    <option value="Philippine Airlines"> Philippine Airlines </option>
                                    <option value="Cebu Pacific"> Cebu Pacific </option>
                                    <option value="AirAsia"> AirAsia </option>
                                    <option value="Qatar Airways"> Qatar Airways </option>
                                    <option value="Emirates"> Emirates </option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label> Price Range (up to) </label>
                                <input type="range" class="form-range" id="priceSlider"
                                    min="1000" max="50000" step="500" value="50000">
                                <small> Max: ₱<span id="priceSliderValue"> 50,000 </span> </small>
                            </div>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" id="directOnly">
                            <label class="form-check-label" for="directOnly"> Direct flights only </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="flexibleDates">
                            <label class="form-check-label" for="flexibleDates"> Flexible dates </label>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <button type="button" class="btn btn-primary w-100" id="searchBtn">
            <span id="searchSpinner" class="spinner-border spinner-border-sm me-2 d-none"></span>
            <span id="searchBtnText"> Search Flights </span>
        </button>

    </div>
</div>

<div id="resultsSection" style="display: none;">

    <div class="card p-3 mb-3">
        <p> Showing <span id="resultsCount"> 0 </span> flights </p>
        <label> Sort by: </label>
        <select id="sortSelect">
            <option value="price"> Price </option>
            <option value="departure"> Departure Time </option>
            <option value="duration"> Duration </option>
        </select>
    </div>

    <div class="row">
        <div class="col-md-3">
            <div class="card p-3">
                <h6> Filters </h6>

                <p> Airlines </p>
                <div id="airlineFilters" class="mb-3">
                    <div class="form-check">
                        <input class="form-check-input filter-airline" type="checkbox" value="Philippine Airlines" id="airlinePA">
                        <label class="form-check-label" for="airlinePA"> Philippine Airlines </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input filter-airline" type="checkbox" value="Cebu Pacific" id="airlineCP">
                        <label class="form-check-label" for="airlineCP"> Cebu Pacific </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input filter-airline" type="checkbox" value="AirAsia" id="airlineAA">
                        <label class="form-check-label" for="airlineAA"> AirAsia </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input filter-airline" type="checkbox" value="Qatar Airways" id="airlineQA">
                        <label class="form-check-label" for="airlineQA"> Qatar Airways </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input filter-airline" type="checkbox" value="Emirates" id="airlineEM">
                        <label class="form-check-label" for="airlineEM"> Emirates </label>
                    </div>
                </div>

                <p> Price Range </p>
                <div class="mb-3">
                    <div class="form-check">
                        <input class="form-check-input filter-price" type="checkbox" value="0-5000" id="price1">
                        <label for="price1"> Under ₱5,000 </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input filter-price" type="checkbox" value="5000-10000" id="price2">
                        <label for="price2"> ₱5,000 - ₱10,000 </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input filter-price" type="checkbox" value="10000-20000" id="price3">
                        <label for="price3"> ₱10,000 - ₱20,000 </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input filter-price" type="checkbox" value="20000-999999" id="price4">
                        <label for="price4"> Over ₱20,000 </label>
                    </div>
                </div>

                <p> Stops </p>
                <div class="mb-3">
                    <div class="form-check">
                        <input class="form-check-input filter-stops" type="checkbox" value="0" id="stops0">
                        <label for="stops0"> Non-stop </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input filter-stops" type="checkbox" value="1" id="stops1">
                        <label for="stops1"> 1 Stop </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input filter-stops" type="checkbox" value="2" id="stops2">
                        <label for="stops2"> 2+ Stops </label>
                    </div>
                </div>

                <p> Departure Time </p>
                <div class="mb-3">
                    <div class="form-check">
                        <input class="form-check-input filter-schedule" type="checkbox" value="morning" id="schedMorning">
                        <label for="schedMorning"> Morning (5AM - 12PM) </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input filter-schedule" type="checkbox" value="afternoon" id="schedAfternoon">
                        <label for="schedAfternoon"> Afternoon (12PM - 6PM) </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input filter-schedule" type="checkbox" value="evening" id="schedEvening">
                        <label for="schedEvening"> Evening (6PM - 12AM) </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input filter-schedule" type="checkbox" value="night" id="schedNight">
                        <label for="schedNight"> Night (12AM - 5AM) </label>
                    </div>
                </div>

                <button class="btn btn-outline-secondary" id="clearFiltersBtn"> Clear Filters </button>
            </div>
        </div>

        <div class="col-md-9">
            <div id="flightResults"></div>
            <div id="noResults" class="text-center d-none">
                <h5> No flights found. </h5>
                <p> Try clearing your filters. </p>
                <button class="btn btn-outline-primary" id="resetFiltersBtn"> Clear Filters </button>
            </div>
        </div>
    </div>

</div>
</div>

<div class="modal fade" id="flightDetailsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"> Flight Details </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="modalBody">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"> Close </button>
                <a href="#" class="btn btn-primary"> Book This Flight </a>
            </div>
        </div>
    </div>
</div>

<div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="searchToast" class="toast text-white">
        <div class="toast-body" id="toastMessage"> Searching... </div>
    </div>
</div>



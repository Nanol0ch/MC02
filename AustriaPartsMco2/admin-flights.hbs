<div class="bg-primary text-white py-4" style="padding-left: 50px; padding-right: 50px;">
    <h2> Flight Schedule Listing </h2>
</div>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <button class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#newFlightModalForm">+ Create New Flight Schedule</button>
        <input type="text" id="searchInput" class="form-control w-25" placeholder="Search flights...">
    </div>

    <table class="table table-bordered table-hover bg-white text-center shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Flight Identifier Code</th>
                <th>Route Direction</th>
                <th>Baseline Price Rate</th>
                <th>Modify Actions</th>
            </tr>
        </thead>
        <tbody id="flightTableBody">
            {{#each flights}}
            <tr id="flight-row-{{this._id}}">
                <td>{{this.flightCode}}</td>
                <td>{{this.route}}</td>
                <td class="rate-display-text">₱{{this.price}}</td>
                <td>
                    <button class="btn btn-sm btn-secondary edit-price-prompt" data-id="{{this._id}}">Edit Price</button>
                    <button class="btn btn-sm btn-danger delete-flight-row" data-id="{{this._id}}">Remove</button>
                </td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</div>

<div class="modal fade" id="newFlightModalForm" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add New Flight</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="dummyFlightForm">
                    <div class="mb-2">
                        <label class="small">Flight Number</label>
                        <input type="text" id="newCode" class="form-control" required>
                    </div>
                    <div class="mb-2">
                        <label class="small">Route Destination</label>
                        <input type="text" id="newRoute" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="small">Price (PHP)</label>
                        <input type="number" id="newPrice" class="form-control" required>
                    </div>
                    <button type="submit" class="btn btn-success btn-sm w-100">Save</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="priceModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Ticket Price</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editPriceId">
                <div class="input-group">
                    <span class="input-group-text">₱</span>
                    <input type="number" id="newPriceInput" class="form-control" placeholder="Enter new price">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="savePriceBtn" class="btn btn-primary">Save Changes</button>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function() {

        $('#dummyFlightForm').submit(function(e) {
            e.preventDefault();
            const flightCode = $('#newCode').val();
            const route = $('#newRoute').val();
            const price = $('#newPrice').val();

            $.ajax({
                url: '/admin/flights',
                type: 'POST',
                data: { flightCode: flightCode, route: route, price: price },
                success: function(response) {
                    const flight = response.flight;
                    $('#flightTableBody').append(`
                        <tr id="flight-row-${flight._id}">
                            <td>${flight.flightCode}</td>
                            <td>${flight.route}</td>
                            <td class="rate-display-text">₱${parseInt(flight.price).toLocaleString()}</td>
                            <td>
                                <button class="btn btn-sm btn-secondary edit-price-prompt" data-id="${flight._id}">Edit Price</button>
                                <button class="btn btn-sm btn-danger delete-flight-row" data-id="${flight._id}">Remove</button>
                            </td>
                        </tr>
                    `);

                    $('#dummyFlightForm')[0].reset();
                    bootstrap.Modal.getInstance(document.getElementById('newFlightModalForm')).hide();
                },
                error: function() {
                    alert("Could not create flight, please check the form.");
                }
            });
        });

        $('#searchInput').on('keyup', function() {
            var value = $(this).val().toLowerCase();
            $("#flightTableBody tr").filter(function() {
                $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
            });
        });

        $(document).on('click', '.edit-price-prompt', function() {
            var flightId = $(this).attr('data-id');
            $('#editPriceId').val(flightId);
            $('#newPriceInput').val('');
            new bootstrap.Modal(document.getElementById('priceModal')).show();
        });

        $('#savePriceBtn').click(function() {
            var flightId = $('#editPriceId').val();
            var newPrice = $('#newPriceInput').val();

            if (newPrice !== "") {
                $.ajax({
                    url: '/admin/flights/' + flightId,
                    type: 'PUT',
                    data: { price: newPrice },
                    success: function(response) {
                        $('#flight-row-' + flightId).find('.rate-display-text').text('₱' + parseInt(response.flight.price).toLocaleString());
                        bootstrap.Modal.getInstance(document.getElementById('priceModal')).hide();
                    },
                    error: function() {
                        alert("Could not update price, please try again.");
                    }
                });
            }
        });

        $(document).on('click', '.delete-flight-row', function() {
            var flightId = $(this).attr('data-id');
            if (confirm("Do you want to delete this flight from list records?")) {
                $.ajax({
                    url: '/admin/flights/' + flightId,
                    type: 'DELETE',
                    success: function() {
                        $('#flight-row-' + flightId).remove();
                    },
                    error: function() {
                        alert("Could not delete this flight, please try again.");
                    }
                });
            }
        });
    });
</script>

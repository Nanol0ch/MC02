<div class="bg-primary text-white py-4" style="padding-left: 50px; padding-right: 50px;">
    <h2> User Registration </h2>
</div>

<div class="container mt-4">
    <div class="row my-3">
        <div class="col-md-6">
            <input type="text" id="filterUserNameBox" class="form-control" placeholder="Search customer by name">
        </div>
    </div>

    <table class="table table-bordered table-striped bg-white text-center shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Customer Name</th>
                <th>Email</th>
                <th>Account Status</th>
                <th>Toggles</th>
            </tr>
        </thead>
        <tbody>
            <tr class="passenger-account-row" data-fullname="Roshni Pathak">
                <td>Roshni Pathak</td>
                <td>roshni.pathak@dlsu.edu.ph</td>
                <td><span class="badge bg-success status-lbl-indicator">Active</span></td>
                <td>
                    <button class="btn btn-sm btn-warning toggle-lockout-state-btn">Toggle Account Status Hold</button>
                </td>
            </tr>
            <tr class="passenger-account-row" data-fullname="Juan Gomez">
                <td>Juan Gomez</td>
                <td>juan.gomez@dlsu.edu.ph</td>
                <td><span class="badge bg-success status-lbl-indicator">Active</span></td>
                <td>
                    <button class="btn btn-sm btn-warning toggle-lockout-state-btn">Toggle Account Status Hold</button>
                </td>
            </tr>
        </tbody>
    </table>
</div>

<script>
    $(document).ready(function() {

        $('.toggle-lockout-state-btn').click(function() {
            var labelBadge = $(this).closest('tr').find('.status-lbl-indicator');

            if (labelBadge.text() == "Active") {
                labelBadge.text("Suspended").removeClass('bg-success').addClass('bg-danger');
            } else {
                labelBadge.text("Active").removeClass('bg-danger').addClass('bg-success');
            }
        });

        $('#filterUserNameBox').on('input', function() {
            var textValueInput = $(this).val().toLowerCase();

            $('.passenger-account-row').each(function() {
                var stringMatchName = $(this).attr('data-fullname').toLowerCase();
                if (stringMatchName.indexOf(textValueInput) > -1) {
                    $(this).show();
                } else {
                    $(this).hide();
                }
            });
        });

    });
</script>

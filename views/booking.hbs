<!-- STEPPER INDICATOR -->

<div class="container mt-4">
  <div class="d-flex justify-content-center align-items-center mb-4 text-center">
    <div class="step text-primary fw-bold" id="indicator1">
      <div class="rounded-circle bg-primary text-white d-inline-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">1</div>
      <div class="small mt-1">Passenger Info</div>
    </div>
    <div class="bg-secondary mx-3" style="height: 2px; width: 50px;"></div>
    <div class="step text-muted" id="indicator2">
      <div class="rounded-circle bg-secondary text-white d-inline-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">2</div>
      <div class="small mt-1">Seat & Extras</div>
    </div>
  </div>
</div>

<!-- MAIN CONTENT -->

<div class="container mb-5">
  <div class="row g-4">

    <!-- LEFT COLUMN: PASSENGER INFO & SEAT/EXTRAS -->
    <div class="col-lg-8">

      <div id="step1">
        <div class="card shadow-sm mb-4">
          <div class="card-header bg-primary text-white fw-bold">
            <i class="bi bi-people-fill me-2"></i> Passenger Information
          </div>
          <div class="card-body">
            
            <div class="mb-4 p-3 bg-light border rounded">
              <h6 class="fw-bold mb-3"><i class="bi bi-people"></i> Who is traveling? (Max 7)</h6>
              <div class="row g-3">
                <div class="col-md-4">
                  <label class="form-label small text-muted fw-bold">Adults (12+ yrs)</label>
                  <input type="number" class="form-control qty-input" id="qtyAdults" value="1" min="1" max="7">
                </div>
                <div class="col-md-4">
                  <label class="form-label small text-muted fw-bold">Children (2-11 yrs)</label>
                  <input type="number" class="form-control qty-input" id="qtyChildren" value="0" min="0" max="6">
                </div>
                <div class="col-md-4">
                  <label class="form-label small text-muted fw-bold">Infants (Under 2)</label>
                  <input type="number" class="form-control qty-input" id="qtyInfants" value="0" min="0" max="7">
                  <div class="form-text" style="font-size: 0.75rem;">Sits on adult's lap</div>
                </div>
              </div>
            </div>

            <form id="passengerForm" class="needs-validation" novalidate>
              
              <div id="passengerFormsContainer"></div>

              <hr class="my-4 border-2">
              <h6 class="text-primary fw-bold mb-3"><i class="bi bi-shield-plus"></i> Primary Emergency Contact</h6>
              <div class="row g-3">
                <div class="col-md-6">
                  <label class="form-label fw-bold">Contact Name <span class="text-danger">*</span></label>
                  <input type="text" class="form-control" id="emName" required>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-bold">Contact Number <span class="text-danger">*</span></label>
                  <input type="text" class="form-control" id="emNumber" required>
                </div>
              </div>

              <div class="text-end mt-4">
                <button type="button" class="btn btn-primary px-4 shadow-sm" id="btnNext">
                  Next: Seat & Extras <i class="bi bi-arrow-right"></i>
                </button>
              </div>
            </form>

          </div>
        </div>
      </div>

      <!-- STEP 2: SEAT & EXTRAS -->
      
      <div id="step2" class="d-none">
        
        <div class="card shadow-sm mb-4">
          <div class="card-header bg-primary text-white fw-bold">
            <i class="bi bi-cup-hot me-2"></i> Meal Selection
          </div>
          <div class="card-body">
            <label class="form-label">Choose your in-flight meal (Applied to all passengers with seats):</label>
            <select class="form-select" id="mealSelect">
              <option value="0" data-desc="Included meal with your ticket.">Standard (Free)</option>
              <option value="150" data-desc="Fresh plant-based meal.">Vegetarian (+₱150)</option>
              <option value="150" data-desc="No animal products whatsoever.">Vegan (+₱150)</option>
              <option value="100" data-desc="Certified Halal-prepared meal.">Halal (+₱100)</option>
              <option value="200" data-desc="Prepared under Kosher supervision.">Kosher (+₱200)</option>
              <option value="180" data-desc="Safe for gluten intolerance.">Gluten-Free (+₱180)</option>
            </select>
            <p class="text-muted small mt-2 mb-0" id="mealDesc"><i class="bi bi-info-circle text-primary me-1"></i> Included meal with your ticket.</p>
          </div>
        </div>

        <div class="card shadow-sm mb-4">
          <div class="card-header bg-primary text-white fw-bold">
            <i class="bi bi-grid-3x3-gap me-2"></i> Seat Selection
          </div>
          <div class="card-body text-center">
            
            <div class="d-flex justify-content-center gap-3 mb-4 small">
              <span><i class="bi bi-square-fill text-success"></i> Available</span>
              <span><i class="bi bi-square-fill text-warning"></i> Premium (+₱500)</span>
              <span><i class="bi bi-square-fill text-primary"></i> Selected</span>
              <span><i class="bi bi-square-fill text-secondary opacity-50"></i> Occupied</span>
            </div>

            <div class="bg-light p-3 rounded d-inline-block border">
              <div id="seatGrid"></div>
            </div>
            
          </div>
        </div>

        <!-- EXTRA SERVICES -->

        <div class="card shadow-sm mb-4">
          <div class="card-header bg-primary text-white fw-bold">
            <i class="bi bi-bag-plus me-2"></i> Extra Services
          </div>
          <div class="card-body">
            <div class="row g-3">
              <div class="col-md-6">
                <div class="border rounded p-3 h-100">
                  <h6 class="fw-bold"><i class="bi bi-briefcase text-primary"></i> Extra Baggage</h6>
                  <p class="small text-muted mb-2">₱500 per additional 5kg bag</p>
                  <div class="input-group input-group-sm w-50">
                    <span class="input-group-text">Qty</span>
                    <input type="number" class="form-control" id="baggageQty" value="0" min="0" max="3">
                  </div>
                </div>
              </div>
              <div class="col-md-6">
                <div class="border rounded p-3 h-100">
                  <h6 class="fw-bold"><i class="bi bi-lightning text-warning"></i> Priority Boarding</h6>
                  <p class="small text-muted mb-2">Board first for ₱300 (Group Fee)</p>
                  <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" id="priorityToggle">
                    <label class="form-check-label small" for="priorityToggle">Add to booking</label>
                  </div>
                </div>
              </div>
              <div class="col-md-6">
                <div class="border rounded p-3 h-100">
                  <h6 class="fw-bold"><i class="bi bi-shield-check text-success"></i> Travel Insurance</h6>
                  <p class="small text-muted mb-2">Medical & cancellation (₱450/person)</p>
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="insuranceCheck">
                    <label class="form-check-label small" for="insuranceCheck">Add Insurance</label>
                  </div>
                </div>
              </div>
              <div class="col-md-6">
                <div class="border rounded p-3 h-100">
                  <h6 class="fw-bold"><i class="bi bi-cup-straw text-info"></i> Lounge Access</h6>
                  <p class="small text-muted mb-2">Relax before your flight (₱1,200/seat)</p>
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="loungeCheck">
                    <label class="form-check-label small" for="loungeCheck">Add Lounge Access</label>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="d-flex justify-content-between mt-4">
          <button type="button" class="btn btn-outline-secondary px-4" id="btnBack"><i class="bi bi-arrow-left"></i> Back</button>
          <button type="button" class="btn btn-success px-4" id="btnCheckout">Proceed to Checkout <i class="bi bi-check-circle"></i></button>
        </div>

      </div>

    </div>

    <!-- RIGHT COLUMN: BOOKING SUMMARY -->
    <div class="col-lg-4">
      <div class="card shadow-sm sticky-top" style="top: 80px;">
        <div class="card-header bg-dark text-white fw-bold">
          <i class="bi bi-receipt me-2"></i> Booking Summary
        </div>
        <div class="card-body">
          
          <p class="mb-1 text-muted small">Flight Details</p>
          
          <!-- Handlebars expression injects the data from the router -->
          <h6 class="fw-bold mb-0" id="summFlightNum">
            <span class="badge bg-primary">{{flight.airline}}</span> {{flight.flightNumber}}</h6>
          <p class="small text-muted mb-3" id="summRoute">{{flight.origin}} ➔ {{flight.destination}}</p>

          <!-- Hidden input to store flight ID and price for our JavaScript -->
          <input type="hidden" id="hiddenFlightId" value="{{flight._id}}">
          <input type="hidden" id="hiddenBaseFare" value="{{flight.price}}">
          <input type="hidden" id="hiddenAvailableSeats" value="{{flight.seats}}">

          <p class="mb-1 text-muted small">Lead Passenger</p>
          <h6 class="fw-bold mb-3" id="summName">Not specified</h6>

          <p class="mb-1 text-muted small">Selected Seat(s)</p>
          <h6 class="fw-bold mb-3 text-primary" id="summSeat">None</h6>

          <a class="text-decoration-none fw-bold d-block mb-2" data-bs-toggle="collapse" href="#priceBreakdown">
            Price Breakdown <i class="bi bi-chevron-down"></i>
          </a>
          
          <div class="collapse show" id="priceBreakdown">
            <div class="d-flex justify-content-between small mb-1">
              <span>Base Fare (Group)</span>
              <span id="costBase">₱0</span>
            </div>
            <div class="d-flex justify-content-between small mb-1">
              <span>Taxes & Fees</span>
              <span id="costTax">₱0</span>
            </div>
            <div class="d-flex justify-content-between small mb-1">
              <span>Seat Selection</span>
              <span id="costSeat">₱0</span>
            </div>
            <div class="d-flex justify-content-between small mb-1">
              <span>Meal Package</span>
              <span id="costMeal">₱0</span>
            </div>
            <div class="d-flex justify-content-between small mb-1">
              <span>Extra Baggage</span>
              <span id="costBaggage">₱0</span>
            </div>
            <div class="d-flex justify-content-between small mb-1">
              <span>Extras</span>
              <span id="costExtras">₱0</span>
            </div>
          </div>

          <hr>
          <div class="d-flex justify-content-between align-items-center">
            <span class="fw-bold fs-5">Total</span>
            <span class="fw-bold fs-4 text-primary" id="grandTotal">₱0</span>
          </div>

        </div>
      </div>
    </div>

  </div>
</div>
